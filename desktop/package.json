{
    "name": "viby-desktop",
    "private": true,
    "version": "0.1.2",
    "type": "module",
    "scripts": {
        "dev:web": "vite --host 127.0.0.1 --port 1420",
        "build:web": "vite build",
        "typecheck": "tsc --noEmit",
        "prepare:icons": "node ../scripts/generate-brand-assets.mjs",
        "prepare:sidecar": "node ./scripts/prepare-sidecar.mjs",
        "repair:tauri-target": "node ./scripts/repair-tauri-target.mjs",
        "tauri:dev": "bun run repair:tauri-target && bun run prepare:icons && tauri dev",
        "tauri:build": "bun run repair:tauri-target && bun run prepare:icons && tauri build"
    },
    "dependencies": {
        "@tauri-apps/api": "2.10.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "@tauri-apps/cli": "2.10.1",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.2",
        "tailwindcss": "^4.2.2",
        "typescript": "^5.9.3",
        "vite": "^7.3.0"
    }
}
