{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Minimal main-window capability set for the desktop control panel.",
    "windows": ["main"],
    "permissions": [
        "core:event:allow-listen",
        "core:event:allow-unlisten",
        "allow-get-hub-snapshot",
        "allow-start-hub",
        "allow-stop-hub",
        "allow-open-preferred-url",
        "allow-copy-text"
    ]
}
