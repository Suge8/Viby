{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Viby Desktop",
    "version": "0.1.0",
    "identifier": "run.viby.desktop",
    "build": {
        "beforeDevCommand": "bun run dev:web",
        "beforeBuildCommand": "bun run build:web",
        "devUrl": "http://127.0.0.1:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Viby Desktop",
                "width": 480,
                "height": 560,
                "resizable": false,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "app"
        ],
        "externalBin": [
            "binaries/viby-sidecar"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
