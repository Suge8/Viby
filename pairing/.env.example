# 必填：broker 自己监听的地址与公网访问地址
PAIRING_HOST=0.0.0.0
PAIRING_PORT=8787
PAIRING_PUBLIC_URL=https://pair.example.com

# 必填：本地 Hub 创建 pairing session 时调用 broker 的共享 secret
PAIRING_CREATE_TOKEN=replace-with-strong-secret

# 强烈建议：生产公网场景至少配 Redis
# 不配时会退回进程内存态；单进程临时测试可以，但重启会丢 pairing 状态
PAIRING_REDIS_URL=redis://127.0.0.1:6379

# 建议：至少配一个 STUN
# 只做局域网演示时可以不配，但公网稳定性会明显变差
PAIRING_STUN_URLS=stun:stun.l.google.com:19302

# 强烈建议：公网生产要有 TURN 服务
# 你可以自建 coturn，也可以换成第三方 TURN 服务；不是必须叫 coturn
PAIRING_TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
PAIRING_TURN_SECRET=replace-with-turn-secret
PAIRING_TURN_REALM=turn.example.com

# 可选：保持默认即可，只有你明确知道要调时再改
PAIRING_SESSION_TTL_SECONDS=2592000
PAIRING_TICKET_TTL_SECONDS=600
PAIRING_RECONNECT_CHALLENGE_TTL_SECONDS=60
PAIRING_TURN_TTL_SECONDS=600
