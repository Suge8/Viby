{
    "name": "viby-pairing",
    "private": true,
    "version": "0.2.0",
    "description": "Pairing broker for Viby remote device linking",
    "license": "AGPL-3.0-only",
    "type": "module",
    "scripts": {
        "dev": "bun --watch run src/index.ts",
        "start": "bun run src/index.ts",
        "build": "VIBY_HARNESS_SCOPE=pairing bun run --cwd .. harness:check && bun build src/index.ts --outdir dist --target bun && bun run scripts/buildDeployBundle.ts",
        "build:deploy-bundle": "bun run build",
        "test": "bun test",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@viby/protocol": "workspace:*",
        "hono": "^4.11.2",
        "redis": "^5.8.2",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@types/node": ">=25",
        "bun-types": "^1.3.11",
        "typescript": "^5.9.3"
    }
}
