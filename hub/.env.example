CLI_API_TOKEN=replace-with-local-hub-token
VIBY_LISTEN_HOST=127.0.0.1
VIBY_LISTEN_PORT=37173

# 服务端配对模式
# 这两个目前是 Hub 的环境变量入口：
# - PAIRING_BROKER_URL: 公网 pairing broker 地址
# - PAIRING_CREATE_TOKEN: Hub 调 broker 创建 pairing 的 secret
# 当前实现还没有把它们写进 ~/.viby/settings.toml
PAIRING_BROKER_URL=https://pair.example.com
PAIRING_CREATE_TOKEN=replace-with-strong-secret
